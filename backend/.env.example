# Copier vers .env et adapter. Ne pas committer .env.

# Supabase (voir aussi .env racine / frontend)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Gmail OAuth (requis pour app/services/gmail.py — aligné sur frontend/.env.local)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Aligné sur frontend — tokens gmail_tokens (AES-256-GCM)
ENCRYPTION_KEY=

DATABASE_URL=

OPENAI_API_KEY=

# Claude — lettres de motivation (prioritaire si renseigné)
ANTHROPIC_API_KEY=

# API SIRENE (INSEE) — clé consommateur : https://portal.api.insee.fr/
# Utilisée par app/services/sirene.py (Bearer).
INSEE_API_KEY=

# n8n — webhook envoi d’e-mails
N8N_WEBHOOK_URL=

# Hunter.io — recherche e-mails pro : https://hunter.io
HUNTER_API_KEY=

# Apollo.io — enrichissement contacts : https://apollo.io
APOLLO_API_KEY=
