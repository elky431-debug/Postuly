# Monorepo : contexte = racine du repo.
# Image Playwright officielle : Chromium déjà présent (évite « playwright install --with-deps »
# qui fait souvent échouer le build Railway : timeout / mémoire).
FROM mcr.microsoft.com/playwright/python:v1.49.0-jammy

WORKDIR /app

COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/ .

ENV PORT=8000
EXPOSE 8000

# Railway injecte souvent PORT ; si absent, 8000 (doit correspondre au port « Public networking »).
CMD ["sh", "-c", "exec uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"]
