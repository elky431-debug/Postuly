# Copier vers .env.local (ne pas committer).

# Obligatoire pour auth / dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# ou : NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Obligatoire pour l’onglet Dashboard Entreprises (proxy /api/entreprises/search).
# Clé consommateur INSEE : https://portal.api.insee.fr/ → en-tête X-INSEE-Api-Key-Integration côté Next.
INSEE_API_KEY=

# Optionnel — site web entreprise (google.serper.dev)
SERPER_API_KEY=

# Optionnel — résolution NAF par IA (Claude Haiku, /api/entreprises/search)
ANTHROPIC_API_KEY=

# Optionnel — URL réelle du backend pour les proxies Next (port 8000). Si absent : 127.0.0.1:8000.
# Ne pas mettre http://localhost:3000 ici.
# BACKEND_PROXY_URL=http://127.0.0.1:8000

# --- Gmail + n8n (routes Next /api/oauth/*, /api/emails/send, /api/n8n/launch-campaign, /api/n8n/campaign-from-selection) ---
# Service role : callback OAuth et appels n8n (ne jamais exposer au client).
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Doit correspondre exactement à l’URI configurée dans la console Google.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/gmail/callback

# Secret pour AES-256-GCM des tokens Gmail (n’importe quelle chaîne ; dérivée en clé 32 octets via SHA-256).
ENCRYPTION_KEY=

# Webhook n8n production + sécurité appels internes
N8N_WEBHOOK_URL=https://postuly.app.n8n.cloud/webhook/postuly-send-email
INTERNAL_API_KEY=
# URL publique de ce frontend (utilisée dans le payload n8n pour rappeler /api/emails/send)
NEXTJS_URL=http://localhost:3000

# Hunter.io / Apollo.io — réservé aux routes API (ne pas préfixer NEXT_PUBLIC_)
HUNTER_API_KEY=
APOLLO_API_KEY=
